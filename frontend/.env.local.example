# ─── Auth ────────────────────────────────────────────────────────────────────
# Clé secrète aléatoire (min 32 caractères) pour signer les JWT de session.
# Générer avec : openssl rand -hex 32
AUTH_SECRET=changez-moi-au-minimum-32-caracteres

# Identifiant de connexion (affiché dans le formulaire "Identifiant")
AUTH_USERNAME=admin

# Hash bcrypt du mot de passe.
# Générer avec : node -e "const b=require('bcryptjs'); b.hash('MON_MDP', 12).then(console.log)"
AUTH_PASSWORD_HASH=$2b$12$HASH_A_REMPLACER

# ─── API FastAPI ──────────────────────────────────────────────────────────────
# En développement : URL directe vers FastAPI local
NEXT_PUBLIC_API_URL=http://localhost:8000

# En production (Cloud Run) : laisser vide → Next.js proxy via rewrites
# NEXT_PUBLIC_API_URL=

# URL interne FastAPI (utilisée par Next.js server-side rewrites en production)
# Exemple Cloud Run : https://hippocampe-api-xxxx-ew.a.run.app
# API_URL=https://hippocampe-api-xxxx-ew.a.run.app
